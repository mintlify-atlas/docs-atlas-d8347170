  "keyFeatures": [
    "Edition lifecycle management (DRAFT → OPEN → CLOSED)",
    "Team registration and management per edition (up to 18 teams)",
    "Match scheduling with referee assignment and table assignment",
    "Score registration and automatic ranking/leaderboard recalculation",
    "Volunteer management with role validation (Judge/Referee conflict prevention)",
    "Project Room judge assignment",
    "Match search and filtering by time, table, and round",
    "HAL/HATEOAS REST API with Spring Data REST",
    "OpenAPI/Swagger documentation via SpringDoc",
    "HTTP Basic authentication with Spring Security"
  ],
  "publicApiSurface": [
    "GET /leaderboards/editions/{editionId}",
    "PATCH /editions/{editionId}/state",
    "POST /editions/{editionId}/teams/{teamId}",
    "GET /editions/{editionId}/volunteers",
    "GET /editions/{editionId}/tables",
    "GET /matches/filter",
    "GET /matches/search/findByTeam",
    "POST /matches/{matchId}/assign-table",
    "POST /matchAssignments/assign",
    "POST /matchAssignments/batch",
    "POST /matchResults/register",
    "POST /project-rooms/assign-judge",
    "GET /identity",
    "POST /users"
  ]
}
